<UserControl x:Class="Plugin.AssetValidator.Views.AssetValidatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A2E">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔍 Asset Validator" FontSize="20" FontWeight="Bold" 
                   Foreground="#E0E0E0" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="0" Text="Scans a folder and validates game asset files for common issues"
                   Foreground="#8892A0" FontSize="12" Margin="0,28,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,12">
            <Button x:Name="BtnSelectFolder" Content="📁 Select Folder" Click="BtnSelectFolder_Click"
                    Background="#0F3460" Foreground="White" Padding="14,8" BorderThickness="0"
                    Cursor="Hand" FontSize="13"/>
            <TextBlock x:Name="TxtFolderPath" Text="No folder selected" Foreground="#8892A0" 
                       FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>

        <ListView x:Name="ResultsList" Grid.Row="2" Background="#161B22" BorderThickness="0"
                  Foreground="#E0E0E0" Margin="0,0,0,8">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Status" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusIcon}" FontSize="16"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="File" Width="250">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileName}" Foreground="#E0E0E0" FontSize="12"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Issue" Width="350">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Message}" Foreground="#8892A0" FontSize="12" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Size" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileSize}" Foreground="#8892A0" FontSize="11"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <TextBlock x:Name="TxtSummary" Text="Select a folder to begin validation" 
                       Foreground="#8892A0" FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>