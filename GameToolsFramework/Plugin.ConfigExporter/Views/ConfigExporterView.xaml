<UserControl x:Class="Plugin.ConfigExporter.Views.ConfigExporterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A2E">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📦 Config Exporter" FontSize="20" FontWeight="Bold" 
                   Foreground="#E0E0E0" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="0" Text="Convert game config files between JSON, CSV, and XML formats"
                   Foreground="#8892A0" FontSize="12" Margin="0,28,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="BtnLoadFile" Content="📄 Load Source File" Click="BtnLoadFile_Click"
                        Background="#0F3460" Foreground="White" Padding="14,8" BorderThickness="0" Cursor="Hand"/>
                <TextBlock x:Name="TxtSourceFile" Text="No file loaded" Foreground="#8892A0" 
                           FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Export as:" Foreground="#8892A0" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button x:Name="BtnExportJson" Content="JSON" Click="BtnExportJson_Click"
                        Background="#E94560" Foreground="White" Padding="14,8" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                <Button x:Name="BtnExportCsv" Content="CSV" Click="BtnExportCsv_Click"
                        Background="#E94560" Foreground="White" Padding="14,8" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                <Button x:Name="BtnExportXml" Content="XML" Click="BtnExportXml_Click"
                        Background="#E94560" Foreground="White" Padding="14,8" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>

        <TextBox x:Name="TxtPreview" Grid.Row="2" Background="#161B22" Foreground="#E0E0E0"
                 BorderThickness="0" FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="12"
                 Text="Load a file to preview its contents..."/>

        <TextBlock x:Name="TxtStatus" Grid.Row="3" Text="" Foreground="#3FB950" FontSize="12" Margin="0,8,0,0"/>
    </Grid>
</UserControl>